# OpenRouter — used for chat completions
OPENROUTER_API_KEY=sk-or-v1-...
OPENROUTER_MODEL=openai/gpt-4o-mini
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1

# Optional metadata sent to OpenRouter for usage attribution
OPENROUTER_SITE_URL=http://localhost:3000
OPENROUTER_APP_NAME=Simple RAG Chatbot

# Chroma — the vector store HTTP server
CHROMA_URL=http://localhost:8000
CHROMA_COLLECTION_NAME=docs

# Local embedding model from @xenova/transformers (runs in-process, no API key)
EMBEDDING_MODEL=Xenova/all-MiniLM-L6-v2

# Where ingestion looks for markdown/text files
DOCS_PATH=./data/docs

# Retrieval / chunking knobs
RETRIEVAL_K=5
CHUNK_SIZE=1000
CHUNK_OVERLAP=150

# Token required to call /api/ingest from the network. Set to a long random string.
# Leave empty to disable the HTTP ingest endpoint entirely (CLI still works).
INGEST_TOKEN=
